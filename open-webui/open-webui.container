[Unit]
Description=Open WebUI - The best frontend for local AI
After=network-online.target

[Container]
Image=ghcr.io/open-webui/open-webui:main
ContainerName=open-webui
PublishPort=8080:8080

# Environment
Environment=OLLAMA_BASE_URL=http://ollama:11434
Environment=OPENAI_API_KEY=unused

#Volumes
Volume=open-webui-data.volume:/app/backend/data

# Networks
Network=ollama.network
Network=searxng.network
Network=traefik.network

# Labels
Label=traefik.http.routers.open-webui.rule=Host(`open-webui.localhost`)
Label=traefik.http.services.open-webui.loadbalancer.server.port=8080

[Service]
Restart=always

[Install]
WantedBy=default.target
