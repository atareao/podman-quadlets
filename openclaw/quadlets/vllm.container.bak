[Unit]
Description=vLLM Service - High Performance Inference
After=network-online.target

[Container]
# We use the official vLLM image
Image=docker.io/vllm/vllm-openai:latest
ContainerName=vllm-engine
PublishPort=8000:8000
# GPU Access (Same as we did before)
AddDevice=nvidia.com/gpu=all

#Force the container to use the host's NVIDIA libraries
Environment=NVIDIA_DRIVER_CAPABILITIES=all
Environment=NVIDIA_VISIBLE_DEVICES=all

Annotation=run.oci.keep_original_groups=1


# We mount a volume to save the models
Volume=vllm_models.volume:/root/.cache/huggingface:Z
# Command to run a specific model (e.g., Mistral or Llama3)

#Exec=--model facebook/opt-125m --gpu-memory-utilization 0.8
Exec=Qwen/Qwen2.5-Coder-7B-Instruct-AWQ --quantization awq --dtype half --gpu-memory-utilization 0.8 --max-model-len 8192 --port 8000  --enable-auto-tool-choice --tool-call-parser hermes
#Exec=--model Qwen/Qwen2.5-Coder-7B-Instruct --dtype half --gpu-memory-utilization 0.85 --max-model-len 8192
#Exec=Qwen/Qwen2.5-Coder-7B-Instruct --dtype bfloat16 --gpu-memory-utilization 0.8 --max-model-len 8192 --port 8000
#Exec=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct --dtype bfloat16 --gpu-memory-utilization 0.8 --max-model-len 8192 --port 8000

[Service]
Restart=always

[Install]
WantedBy=default.target
